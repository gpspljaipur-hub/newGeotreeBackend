  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:5030" },
    { "key": "TOKEN", "value": "PASTE_YOUR_JWT_TOKEN_HERE" }
  ],
  "item": [
    {
      "name": "State",
      "item": [
        {
          "name": "List States",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"page\": 1,\n  \"limit\": 20,\n  \"status\": true\n}" },
            "url": { "raw": "{{BASE_URL}}/api/state/list", "host": ["{{BASE_URL}}"], "path": ["api","state","list"] }
          }
        },
        {
          "name": "State Hierarchy",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/state/hierarchy", "host": ["{{BASE_URL}}"], "path": ["api","state","hierarchy"] }
          }
        },
        {
          "name": "Add State (multipart)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "state_name", "value": "Maharashtra", "type": "text" },
                { "key": "state_image", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{BASE_URL}}/api/state/add", "host": ["{{BASE_URL}}"], "path": ["api","state","add"] }
          }
        },
        {
          "name": "Update State (multipart)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "id", "value": "64f1234abc5678def9012345", "type": "text" },
                { "key": "state_name", "value": "Maharashtra Updated", "type": "text" },
                { "key": "state_image", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{BASE_URL}}/api/state/update", "host": ["{{BASE_URL}}"], "path": ["api","state","update"] }
          }
        },
        {
          "name": "Delete State",
          "request": {
