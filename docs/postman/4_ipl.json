  "item": [
    {
      "name": "Campaigns",
      "item": [
        {
          "name": "List Campaigns",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"page\": 1,\n  \"limit\": 10\n}" },
            "url": { "raw": "{{BASE_URL}}/api/ipl/campaigns/list", "host": ["{{BASE_URL}}"], "path": ["api","ipl","campaigns","list"] }
          }
        },
        {
          "name": "Add Campaign",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"campaign_name\": \"IPL 2025\",\n  \"start_date\": \"2025-03-15\",\n  \"end_date\": \"2025-05-30\",\n  \"description\": \"IPL cricket campaign for tree plantation\"\n}" },
